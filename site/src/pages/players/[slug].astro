---
import CountingList from '../../components/CountingList.astro';
import StatGrid from '../../components/StatGrid.astro';
import SampleDataBanner from '../../components/SampleDataBanner.astro';
import PlayerHero from '../../components/PlayerHero.astro';
import SliderPanel from '../../components/SliderPanel.astro';
import Base from '../../layouts/Base.astro';
import { getLeagueByKey, getPlayers, isSampleLeague } from '../../lib/data';
import type { Player } from '../../lib/data';

export function getStaticPaths() {
  return getPlayers().map((p) => ({ params: { slug: p.slug }, props: { player: p } }));
}

interface Props {
  player: Player;
}
const { player } = Astro.props;
const league = getLeagueByKey(player.summer.leagueKey);
const sample = isSampleLeague(player.summer.leagueKey);
const firstName = player.name.split(' ')[0];
const hasStats = Boolean(player.hitting || player.pitching);
const side = player.hitting ? 'hitters' : 'pitchers';
---
<Base title={`${player.name} — GT Summer Tracker`}>
  {sample && <SampleDataBanner leagueName={league?.name ?? 'League'} />}
  <article class="card profile">
    <PlayerHero player={player} league={league} />

    {hasStats && league && (
      <div class="strip">
        <span class="dot">i</span>
        Percentiles rank {firstName} against all <strong>{league.name}</strong> {side},
        2026 season · stats through {player.asOf}
      </div>
    )}

    {!hasStats && (
      <div class="empty">
        {player.summer.status === 'assigned'
          ? `Stats for ${firstName} aren't flowing yet — the ${league?.name ?? 'league'} feed is coming online soon.`
          : player.summer.status === 'not_playing'
            ? `${firstName} is not playing summer ball this year.`
            : `${firstName} doesn't have a confirmed summer team yet. Check back soon.`}
      </div>
    )}

    {hasStats && (
      <div class="body">
        <div class="left">
          {(['hitting', 'pitching'] as const).map((s) =>
            player[s] ? (
              <section>
                <h2 class="section-title">{player.hitting && player.pitching ? `Season Stats — ${s === 'hitting' ? 'Batting' : 'Pitching'}` : 'Season Stats'}</h2>
                <StatGrid block={player[s]!} side={s} />
                <CountingList block={player[s]!} side={s} />
              </section>
            ) : null
          )}
        </div>
        <div class="right">
          {(['hitting', 'pitching'] as const).map((s) =>
            player[s] && league ? (
              <SliderPanel block={player[s]!} leagueName={league.name} side={s}
                dual={Boolean(player.hitting && player.pitching)} />
            ) : null
          )}
        </div>
      </div>
    )}
  </article>
</Base>

<style>
  .profile { overflow: hidden; }
  .strip {
    background: #eef1f5;
    border-bottom: 1px solid var(--line);
    padding: 7px 22px;
    font-size: 12px;
    color: #5b6472;
  }
  .dot {
    display: inline-block;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--gold);
    color: var(--navy-dark);
    text-align: center;
    font-weight: 800;
    font-size: 10px;
    line-height: 14px;
    margin-right: 6px;
  }
  .empty { padding: 26px 22px; color: var(--text-mut); font-size: 14px; }
  .body {
    display: flex;
    gap: 24px;
    padding: 20px 22px;
    background: var(--bg);
  }
  .left { flex: 0 0 40%; min-width: 0; }
  .right { flex: 1; min-width: 0; }
  .left section + section { margin-top: 20px; }
  @media (max-width: 700px) {
    .body { flex-direction: column; }
    .left { flex: 1; }
  }
</style>
