---
import { percentileColor } from '../lib/colors';

interface Props {
  percentile: number | null;
}
const { percentile } = Astro.props;
---
{percentile === null ? (
  <span class="chip none">—</span>
) : (
  <span class="chip" style={`background:${percentileColor(percentile)}`}>{percentile}</span>
)}

<style>
  .chip {
    display: inline-block;
    min-width: 26px;
    text-align: center;
    color: #fff;
    border-radius: 10px;
    padding: 1px 8px;
    font-size: 11px;
    font-weight: 800;
  }
  .none { background: #c3c9d4; }
</style>
