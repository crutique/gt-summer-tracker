---
interface Props {
  leagueName: string;
}
const { leagueName } = Astro.props;
---
<div class="banner">
  <strong>Sample data.</strong> {leagueName} statistics shown here are placeholder
  data while the live stats feed is being built — they are not real results.
</div>

<style>
  .banner {
    background: #fdf3dd;
    border: 1px solid #e8d5a4;
    color: #92600a;
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 13px;
    margin: 0 0 14px;
  }
</style>
